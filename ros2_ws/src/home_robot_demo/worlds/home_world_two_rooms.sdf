      <joint name="north_to_east_left" type="fixed">
        <parent>north_wall</parent>
        <child>east_wall_left</child>
      </joint>
      <joint name="north_to_west" type="fixed">
        <parent>north_wall</parent>
        <child>west_wall</child>
      </joint>
      <joint name="west_to_south" type="fixed">
        <parent>west_wall</parent>
        <child>south_wall</child>
      </joint>
      <joint name="south_to_east_right" type="fixed">
