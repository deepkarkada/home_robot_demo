            <diffuse>0.85 0.85 0.85 1</diffuse>
          </material>
        </visual>
      </link>
      
      <include>
        <name>Couch0</name>
        <pose>-2.0 -1.5 0 0 0 0</pose>
        <uri>
          https://fuel.gazebosim.org/1.0/OpenRobotics/models/Sofa
        </uri>
      </include>

      <include>
        <name>Table0</name>
        <pose>0 2.0 0 0 0 0</pose>
        <uri>
          https://fuel.gazebosim.org/1.0/OpenRobotics/models/Cafe table
        </uri>
