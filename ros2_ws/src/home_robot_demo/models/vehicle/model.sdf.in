<?xml version="1.0" ?>
<sdf version="1.8">
  <model name="vehicle" canonical_link="chassis">
    <pose>0 0 0 0 0 0</pose>
    
    <frame name="lidar_frame" attached_to='chassis'>
      <pose>0.8 0 0.5 0 0 0</pose>
    </frame>

    <link name="chassis">
      <pose>0 0 0.18 0 0 0</pose>

      <inertial>
          <mass>10.0</mass>
          <inertia>
            <ixx>0.133</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.266</iyy>
            <iyz>0</iyz>
            <izz>0.3466</izz>
          </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <box>
            <size>0.60 0.40 0.10</size>
          </box>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <box>
            <size>0.60 0.40 0.20</size>
          </box>
        </geometry>
        <material>
          <ambient>0.0 0.0 1.0 1</ambient>
          <diffuse>0.0 0.0 1.0 1</diffuse>
          <specular>0.0 0.0 1.0 1</specular>
        </material>
      </visual>
    </link>

    <!-- Torso -->
    <link name="torso">
      <pose relative_to="chassis">0 0 0.22 0 0 0</pose>

      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.018</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0064</iyy>
          <iyz>0</iyz>
          <izz>0.014</izz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <box>
            <size>0.12 0.4 0.25</size>
          </box>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <box>
            <size>0.12 0.4 0.25</size>
          </box>
        </geometry>
        <material>
          <ambient>1.0 1.0 0.5 1.0</ambient>
          <diffuse>1.0 1.0 0.5 1.0</diffuse>
          <specular>1.0 1.0 0.5 1.0</specular>
        </material>
      </visual>
    </link>

    <!--Head on top of torso -->
    <link name="head">
      <pose relative_to="torso">0 0 0.15 0 0 0</pose>

      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.00007</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00002</iyy>
          <iyz>0</iyz>
          <izz>0.00005</izz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <box>
            <size>0.02 0.08 0.05</size>
          </box>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <box>
            <size>0.02 0.08 0.05</size>
          </box>
        </geometry>
        <material>
          <ambient>0.0 0.0 0.75 1.0</ambient>
          <diffuse>0.0 0.0 0.75 1.0</diffuse>
          <specular>0.0 0.0 0.75 1.0</specular>
        </material>
      </visual>
    </link>

    <!-- Wheels -->
    <!-- Left Front -->
    <link name="left_front_wheel">
      <pose relative_to="chassis">0.15 0.18 -0.10 -1.5707 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.0009</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0009</iyy>
          <iyz>0</iyz>
          <izz>0.0016</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.08</radius><length>0.05</length></cylinder></geometry>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.08</radius><length>0.05</length></cylinder></geometry>
      </visual>
    </link>

    <!-- Right Front -->
    <link name="right_front_wheel">
      <pose relative_to="chassis">0.15 -0.18 -0.10 -1.5707 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.0009</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0009</iyy>
          <iyz>0</iyz>
          <izz>0.0016</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.08</radius><length>0.05</length></cylinder></geometry>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.08</radius><length>0.05</length></cylinder></geometry>
      </visual>
    </link>

    <!-- Left Back -->
    <link name="left_back_wheel">
      <pose relative_to="chassis">-0.15 0.18 -0.10 -1.5707 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.0009</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0009</iyy>
          <iyz>0</iyz>
          <izz>0.0016</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.08</radius><length>0.05</length></cylinder></geometry>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.08</radius><length>0.05</length></cylinder></geometry>
      </visual>
    </link>

    <!-- Right Back -->
    <link name="right_back_wheel">
      <pose relative_to="chassis">-0.15 -0.18 -0.10 -1.5707 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.0009</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0009</iyy>
          <iyz>0</iyz>
          <izz>0.0016</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.08</radius><length>0.05</length></cylinder></geometry>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.08</radius><length>0.05</length></cylinder></geometry>
      </visual>
    </link>

    <!-- LIDAR of height width 0.04-->
    <link name="lidar_link">
      <!--pose relative_to="chassis">0.15 0 0.125 0 0 0</pose -->
      <pose>0.085 0 0.32 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.00004</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00004</iyy>
          <iyz>0</iyz>
          <izz>0.00004</izz>
        </inertia>
      </inertial>

      <visual name="visual">
        <geometry>
          <box>
            <size>0.04 0.04 0.04</size>
          </box>
        </geometry>
          <material>
            <ambient>0.2 0.2 0.2 1</ambient>
            <diffuse>0.2 0.2 0.2 1</diffuse>
          </material>
      </visual>
      <sensor name="lidar" type="gpu_lidar">
        <topic>/scan</topic>
        <update_rate>10</update_rate>
        <ray>
          <scan>
           <horizontal>
           <samples>640</samples>
           <resolution>1</resolution>
           <min_angle>-1.396263</min_angle>
           <max_angle>1.396263</max_angle>
           </horizontal>
           <vertical>
           <samples>1</samples>
           <resolution>0.01</resolution>
           <min_angle>0</min_angle>
           <max_angle>0</max_angle>
           </vertical>
          </scan>
         <range>
          <min>0.08</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
         </range>
        </ray>
        <always_on>1</always_on>
        <visualize>true</visualize>
      </sensor>
    </link>

    <!-- Camera mounted on torso facing forward -->
    <link name="camera_link">
      <pose relative_to="torso">0.085 0 0.08 0 0 0</pose>

      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.00004</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00004</iyy>
          <iyz>0</iyz>
          <izz>0.00004</izz>
        </inertia>
      </inertial>

      <visual name="visual">
        <geometry>
          <box>
            <size>0.05 0.05 0.05</size>
          </box>
        </geometry>
        <material>
          <ambient>0 0 0 1</ambient>
        </material>
      </visual>

      <sensor name="front_camera" type="camera">
        <topic>/camera/image</topic>
        <update_rate>20</update_rate>
        <camera>
          <horizontal_fov>1.5708</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.05</near>
            <far>20.0</far>
          </clip>
        </camera>
        <always_on>true</always_on>
        <visualize>true</visualize>
      </sensor>
    </link>

    <!-- ========================= -->
    <!-- LEFT ARM -->
    <!-- ========================= -->
    <!-- =========================
     LEFT ARM (3 DOF)
     DOF 1: shoulder yaw
     DOF 2: shoulder pitch
     DOF 3: gripper open/close
     ========================= -->

    <link name="left_shoulder_link">
      <pose relative_to="torso">0 0.24 0.08 0 0 0</pose>
      <inertial>
        <mass>0.03</mass>
        <inertia>
          <ixx>0.0002</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0002</iyy>
          <iyz>0</iyz>
          <izz>0.0002</izz>
        </inertia>
      </inertial>
      <collision name="left_shoulder_collision">
        <geometry>
          <sphere>
            <radius>0.035</radius>
          </sphere>
        </geometry>
      </collision>
      <visual name="left_shoulder_visual">
        <geometry>
          <sphere>
            <radius>0.035</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.85 0.2 0.2 1</ambient>
          <diffuse>0.85 0.2 0.2 1</diffuse>
          <specular>0.85 0.2 0.2 1</specular>
        </material>
      </visual>
    </link>

    <link name="left_upper_arm_link">
      <pose relative_to="left_shoulder_link">0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 -0.10 0 0 0</pose>
        <mass>0.07</mass>
        <inertia>
          <ixx>0.0015</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0015</iyy>
          <iyz>0</iyz>
          <izz>0.0002</izz>
        </inertia>
      </inertial>
      <collision name="left_upper_arm_collision">
        <pose>0 0 -0.10 0 0 0</pose>
        <geometry>
          <box>
            <size>0.04 0.04 0.20</size>
          </box>
        </geometry>
      </collision>
      <visual name="left_upper_arm_visual">
        <pose>0 0 -0.10 0 0 0</pose>
        <geometry>
          <box>
            <size>0.04 0.04 0.20</size>
          </box>
        </geometry>
        <material>
          <ambient>0.9 0.35 0.35 1</ambient>
          <diffuse>0.9 0.35 0.35 1</diffuse>
          <specular>0.9 0.35 0.35 1</specular>
        </material>
      </visual>
    </link>

    <link name="left_forearm_link">
      <pose relative_to="left_upper_arm_link">0 0 -0.20 0 0 0</pose>
      <inertial>
        <pose>0 0 -0.09 0 0 0</pose>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.0008</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0008</iyy>
          <iyz>0</iyz>
          <izz>0.00015</izz>
        </inertia>
      </inertial>
      <collision name="left_forearm_collision">
        <pose>0 0 -0.09 0 0 0</pose>
        <geometry>
          <box>
            <size>0.035 0.035 0.18</size>
          </box>
        </geometry>
      </collision>
      <visual name="left_forearm_visual">
        <pose>0 0 -0.09 0 0 0</pose>
        <geometry>
          <box>
            <size>0.035 0.035 0.18</size>
          </box>
        </geometry>
        <material>
          <ambient>0.8 0.15 0.15 1</ambient>
          <diffuse>0.8 0.15 0.15 1</diffuse>
          <specular>0.8 0.15 0.15 1</specular>
        </material>
      </visual>
    </link>

    <link name="left_gripper_link">
      <pose relative_to="left_forearm_link">0 0 -0.18 0 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>5e-6</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>5e-6</iyy>
          <iyz>0</iyz>
          <izz>5e-6</izz>
        </inertia>
      </inertial>
      <collision name="left_gripper_collision">
        <geometry>
          <box>
            <size>0.04 0.02 0.02</size>
          </box>
        </geometry>
      </collision>
      <visual name="left_gripper_visual">
        <geometry>
          <box>
            <size>0.04 0.02 0.02</size>
          </box>
        </geometry>
        <material>
          <ambient>0.6 0.6 0.6 1</ambient>
          <diffuse>0.6 0.6 0.6 1</diffuse>
          <specular>0.6 0.6 0.6 1</specular>
        </material>
      </visual>
    </link>

    <link name="left_finger_left">
      <pose relative_to="left_gripper_link">0 0.012 0 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia>
          <ixx>1e-6</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-6</iyy>
          <iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>
      <collision name="left_finger_left_collision">
        <geometry>
          <box>
            <size>0.03 0.008 0.01</size>
          </box>
        </geometry>
      </collision>
      <visual name="left_finger_left_visual">
        <geometry>
          <box>
            <size>0.03 0.008 0.01</size>
          </box>
        </geometry>
      </visual>
    </link>

    <link name="left_finger_right">
      <pose relative_to="left_gripper_link">0 -0.012 0 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia>
          <ixx>1e-6</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-6</iyy>
          <iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>
      <collision name="left_finger_right_collision">
        <geometry>
          <box>
            <size>0.03 0.008 0.01</size>
          </box>
        </geometry>
      </collision>
      <visual name="left_finger_right_visual">
        <geometry>
          <box>
            <size>0.03 0.008 0.01</size>
          </box>
        </geometry>
      </visual>
    </link>

    <joint name="left_shoulder_yaw_joint" type="revolute">
      <parent>torso</parent>
      <child>left_shoulder_link</child>
      <axis>
        <xyz expressed_in="__model__">0 0 1</xyz>
        <limit>
          <lower>-1.5708</lower>
          <upper>1.5708</upper>
          <effort>10</effort>
          <velocity>1.5</velocity>
        </limit>
        <dynamics>
          <damping>5.0</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="left_shoulder_pitch_joint" type="revolute">
      <parent>left_shoulder_link</parent>
      <child>left_upper_arm_link</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1.5708</lower>
          <upper>1.5708</upper>
          <effort>10</effort>
          <velocity>1.5</velocity>
        </limit>
        <dynamics>
          <damping>5.0</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="left_elbow_fixed_joint" type="fixed">
      <parent>left_upper_arm_link</parent>
      <child>left_forearm_link</child>
    </joint>

    <joint name="left_gripper_link_fixed_joint" type="fixed">
      <parent>left_forearm_link</parent>
      <child>left_gripper_link</child>
    </joint>

    <joint name="left_finger_left_joint" type="prismatic">
      <parent>left_gripper_link</parent>
      <child>left_finger_left</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>0.0</lower>
          <upper>0.015</upper>
          <effort>5</effort>
          <velocity>0.2</velocity>
        </limit>
        <dynamics>
          <damping>0.2</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="left_finger_right_joint" type="prismatic">
      <parent>left_gripper_link</parent>
      <child>left_finger_right</child>
      <axis>
        <xyz>0 -1 0</xyz>
        <limit>
          <lower>0.0</lower>
          <upper>0.015</upper>
          <effort>5</effort>
          <velocity>0.2</velocity>
        </limit>
        <dynamics>
          <damping>0.2</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- ========================= -->
    <!-- RIGHT ARM -->
    <!-- ========================= -->
    <!-- =========================
     RIGHT ARM (3 DOF)
     DOF 1: shoulder yaw
     DOF 2: shoulder pitch
     DOF 3: gripper open/close
     ========================= -->

    <link name="right_shoulder_link">
      <pose relative_to="torso">0 -0.24 0.08 0 0 0</pose>
      <inertial>
        <mass>0.03</mass>
        <inertia>
          <ixx>0.0002</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0002</iyy>
          <iyz>0</iyz>
          <izz>0.0002</izz>
        </inertia>
      </inertial>
      <collision name="right_shoulder_collision">
        <geometry>
          <sphere>
            <radius>0.035</radius>
          </sphere>
        </geometry>
      </collision>
      <visual name="right_shoulder_visual">
        <geometry>
          <sphere>
            <radius>0.035</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.85 0.2 0.2 1</ambient>
          <diffuse>0.85 0.2 0.2 1</diffuse>
          <specular>0.85 0.2 0.2 1</specular>
        </material>
      </visual>
    </link>

    <link name="right_upper_arm_link">
      <pose relative_to="right_shoulder_link">0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 -0.10 0 0 0</pose>
        <mass>0.07</mass>
        <inertia>
          <ixx>0.0015</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0015</iyy>
          <iyz>0</iyz>
          <izz>0.0002</izz>
        </inertia>
      </inertial>
      <collision name="right_upper_arm_collision">
        <pose>0 0 -0.10 0 0 0</pose>
        <geometry>
          <box>
            <size>0.04 0.04 0.20</size>
          </box>
        </geometry>
      </collision>
      <visual name="right_upper_arm_visual">
        <pose>0 0 -0.10 0 0 0</pose>
        <geometry>
          <box>
            <size>0.04 0.04 0.20</size>
          </box>
        </geometry>
        <material>
          <ambient>0.9 0.35 0.35 1</ambient>
          <diffuse>0.9 0.35 0.35 1</diffuse>
          <specular>0.9 0.35 0.35 1</specular>
        </material>
      </visual>
    </link>

    <joint name="right_shoulder_yaw_joint" type="revolute">
      <parent>torso</parent>
      <child>right_shoulder_link</child>
      <axis>
        <xyz expressed_in="__model__">0 0 1</xyz>
        <limit>
          <lower>-1.5708</lower>
          <upper>1.5708</upper>
          <effort>10</effort>
          <velocity>1.5</velocity>
        </limit>
        <dynamics>
          <damping>2.0</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="right_shoulder_pitch_joint" type="revolute">
      <parent>right_shoulder_link</parent>
      <child>right_upper_arm_link</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1.5708</lower>
          <upper>1.5708</upper>
          <effort>10</effort>
          <velocity>1.5</velocity>
        </limit>
        <dynamics>
          <damping>2.0</damping>
        </dynamics>
      </axis>
    </joint>
    

    <!-- Joints -->
    <joint name="torso_joint" type="fixed">
      <parent>chassis</parent>
      <child>torso</child>
    </joint>

    <joint name="head_joint" type="fixed">
      <parent>torso</parent>
      <child>head</child>
    </joint>

    <joint name="camera_joint" type="fixed">
      <parent>torso</parent>
      <child>camera_link</child>
    </joint>

    <joint name="left_back_wheel_joint" type="revolute">
        <pose relative_to="left_back_wheel">0 0 0 0 0 0</pose>
        <parent>chassis</parent>
        <child>left_back_wheel</child>
        <axis>
          <xyz expressed_in="__model__">0 1 0</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
          </limit>
        </axis>
      </joint>

      <joint name="left_front_wheel_joint" type="revolute">
        <pose relative_to="left_front_wheel">0 0 0 0 0 0</pose>
        <parent>chassis</parent>
        <child>left_front_wheel</child>
        <axis>
          <xyz expressed_in="__model__">0 1 0</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
          </limit>
        </axis>
      </joint>

      <joint name="right_front_wheel_joint" type="revolute">
        <pose relative_to="right_front_wheel">0 0 0 0 0 0</pose>
        <parent>chassis</parent>
        <child>right_front_wheel</child>
        <axis>
          <xyz expressed_in="__model__">0 1 0</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
          </limit>
        </axis>
      </joint>

      <joint name="right_back_wheel_joint" type="revolute">
        <pose relative_to="right_back_wheel">0 0 0 0 0 0</pose>
        <parent>chassis</parent>
        <child>right_back_wheel</child>
        <axis>
          <xyz expressed_in="__model__">0 1 0</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
          </limit>
        </axis>
      </joint>

    <joint name="lidar_joint" type="fixed">
      <parent>chassis</parent>
      <child>lidar_link</child>
    </joint>



    <!-- ROS2 CONTROL -->
    <ros2_control name="GazeboSystem" type="system">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>

      <joint name="left_front_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="right_front_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="left_back_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="right_back_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>

    <plugin filename="libgz-sim-sensors-system.so"
        name="gz::sim::systems::Sensors"/>

    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
      <parameters>{{CONTROLLERS_YAML}}</parameters>
    </plugin>

  </model>
</sdf>